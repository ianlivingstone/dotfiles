tmux:3.7
tig:2.6.1
starship:1.25.1
jq:1.8.2
rg:15.1.0
luarocks:3.13.0
gpg:2.5.20
duckdb:1.5.4
jj:0.42.0
delta:0.16.0
gh:2.95.0

# Programming languages (required)
node:v24.18.0
go:go1.26.4
python:3.14
gopls:0.22.0

# Development managers (required)
nvm:0.39
gvm:1.0
rustup:1.25
uv:0.11.25

