# Machine-specific state files that should never be committed

# Neovim backup files from migration
nvim/.config/nvim/init.lua.backup
nvim/.config/nvim/*.backup

# Any machine-specific configuration backups
*.backup
*.local
*.machine

# Claude Code local settings (but not shared settings.json)
.claude/settings.local.json

# Common editor temporary files
.DS_Store
*.swp
*.swo
*~

# Node.js
**/node_modules/

# Rust build artifacts
**/target/

# Any accidentally created machine configs in wrong location
**/machine.config
**/machines/
.claude/hook-output.log

# Secrets / keys / credentials — never commit these (defense against an accidental `git add .`)
.env
.env.*
*.env
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
id_ecdsa
id_dsa
*.id_rsa
credentials
.netrc
.gnupg/
**/.gnupg/
known_hosts
authorized_keys
