{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch"
    ],
    "deny": [
      "Bash(git add:*)",
      "Bash(git commit:*)"
    ]
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true,
  "theme": "auto",
  "autoUpdate": false,
  "tui": "fullscreen"
}
